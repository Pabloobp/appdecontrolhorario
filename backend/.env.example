# Copia este archivo como .env y rellena los valores
# Copy this file as .env and fill in the values

# Cadena de conexión a la base de datos (PostgreSQL / Supabase)
# Database connection string (PostgreSQL / Supabase)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clave secreta para firmar los tokens JWT (genera una larga y aleatoria)
# Secret key for signing JWT tokens (generate a long, random one)
# You can run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# Algoritmo para JWT (no cambiar)
# JWT algorithm (do not change)
JWT_ALGORITHM=HS256

# Expiración del token en minutos
# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=10080
