# URL de conexión a la base de datos
# Opciones:
#   PostgreSQL: postgresql://usuario:contraseña@host:5432/nombre_db
#   SQLite local (sin instalar nada): sqlite:///./controlhorario.db
DATABASE_URL=sqlite:///./controlhorario.db

# Clave secreta para firmar tokens JWT (cambia esto en producción)
SECRET_KEY=cambia-esta-clave-secreta-en-produccion-min-32-chars

# Algoritmo JWT
ALGORITHM=HS256

# Minutos de expiración del token (480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480
